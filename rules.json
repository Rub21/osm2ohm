{
  "_comment": "Rules to identify deleted OSM objects that are good candidates for OpenHistoricalMap (OHM).",

  "object_types": ["node", "way"],

  "min_versions": 5,
  "min_distinct_users": 3,
  "min_lifetime_days": 180,
  "min_age_at_deletion_days": 365,

  "must_be_deleted": true,
  "exclude_deletions_by_creator": true,

  "_tags_comment": "Trailing '*' = prefix match. e.g. 'name:*' matches name:es, name:de, name:zh, etc.",
  "required_tags_any": [
    "name", "name:*", "old_name", "old_name:*", "alt_name", "alt_name:*", "loc_name",

    "historic", "historic:*", "heritage", "heritage:*",
    "memorial", "monument", "ruins", "ruins:*", "archaeological_site",

    "building", "building:*",

    "amenity", "tourism", "leisure", "shop", "office", "craft",

    "highway", "railway", "aeroway", "waterway", "bridge", "tunnel", "ford",

    "landuse", "natural", "place", "boundary", "boundary:*",

    "man_made", "power", "military", "industrial",

    "religion", "denomination",

    "start_date", "end_date", "opening_date", "construction_date",

    "abandoned", "abandoned:*", "disused", "disused:*",
    "demolished", "demolished:*", "destroyed", "destroyed:*",
    "razed", "razed:*", "was:*", "removed:*"
  ],

  "exclude_tags_keys": ["fixme", "FIXME", "note", "todo"],

  "min_tag_count_last_visible": 3,

  "way_min_nodes": 3
}
